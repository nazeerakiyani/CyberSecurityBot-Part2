<Window x:Class="CyberSecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" 
        Height="600" 
        Width="800"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Define rows: Header, Chat area, Input area -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER: ASCII Art and Title -->
        <Border Grid.Row="0" 
                Background="#16213e" 
                BorderBrush="#0f3460" 
                BorderThickness="0,0,0,2" 
                Padding="15">
            <StackPanel>
                <!-- ASCII Art Display -->
                <TextBlock x:Name="AsciiArtTextBlock"
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="#e94560"
                           TextAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Title -->
                <TextBlock Text="Cybersecurity Awareness Assistant"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#eaeaea"
                           TextAlignment="Center"/>

                <!-- Subtitle -->
                <TextBlock Text="Keeping South Africa Safe Online"
                           FontSize="12"
                           Foreground="#a0a0a0"
                           TextAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- CHAT AREA: Scrollable conversation -->
        <Border Grid.Row="1" 
                Background="#0f3460" 
                Margin="10" 
                CornerRadius="8"
                BorderBrush="#e94560" 
                BorderThickness="1">
            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Margin="10">
                <StackPanel x:Name="ChatStackPanel">
                    <!-- Chat messages will appear here -->
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- INPUT AREA: Text box and Send button -->
        <Border Grid.Row="2" 
                Background="#16213e" 
                Padding="15" 
                BorderBrush="#0f3460" 
                BorderThickness="0,2,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- User Input TextBox -->
                <TextBox x:Name="UserInputTextBox"
                         Grid.Column="0"
                         Height="40"
                         FontSize="14"
                         Background="#1a1a2e"
                         Foreground="#eaeaea"
                         BorderBrush="#e94560"
                         BorderThickness="1"
                         Padding="10,8"
                         VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>

                <!-- Send Button -->
                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send"
                        Width="100"
                        Height="40"
                        Background="#e94560"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>